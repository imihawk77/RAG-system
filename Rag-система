        "# Query rewrite + metadata filters\n",
        "def heuristic_rewrite(q: str) -> List[str]:\n",
        "    # 3 варианта запроса\n",
        "    base = q.strip()\n",
        "    return [\n",
        "        base,\n",
        "        re.sub(r\"[^\\w\\sа-яА-ЯёЁ]\", \" \", base),\n",
        "        f\"Ключевые требования и риски: {base}\",\n",
        "    ]\n",
        "\n",
        "def filter_by_metadata(docs: List[Document], doc_type: Optional[str]=None) -> List[Document]:\n",
        "    if not doc_type:\n",
        "        return docs\n",
        "    return [d for d in docs if d.metadata.get(\"doc_type\") == doc_type]\n"
      ],
      "metadata": {
        "id": "XRqHCEYpwiiO"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Простая безопасность (фильтрация)\n",
        "BANNED_PATTERNS = [\n",
        "    r\"\\bпарол(ь|и)\\b\", r\"\\bвзлом\\b\", r\"\\bобойти\\b.*\\bбезопасност\", r\"\\bинъекц\", r\"\\bsql\\s*injection\\b\",\n",
        "    r\"\\bоружи\", r\"\\bсамодел\", r\"\\bбомб\", r\"\\bнаркот\",\n",
        "]\n",
        "\n",
        "def safety_check(user_query: str) -> Tuple[bool, Optional[str]]:\n",
        "    q = user_query.lower()\n",
        "    for p in BANNED_PATTERNS:\n",
        "        if re.search(p, q):\n",
        "            return False, \"Запрос выглядит небезопасно. Я не помогу с этим. Могу подсказать безопасные альтернативы (защита, аудит, общие принципы).\"\n",
        "    return True, None\n"
      ],
      "metadata": {
        "id": "OmFHdsK7wioq"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Retrieval пайплайн (rewrite → retrieve → rerank → контекст)\n",
        "def retrieve(query: str, doc_type: Optional[str]=None, k: int=18) -> List[Document]:\n",
        "    rewrites = heuristic_rewrite(query)\n",
        "    pool = []\n",
        "    for rq in rewrites:\n",
        "        hits = vs.similarity_search(rq, k=k)\n",
        "        pool.extend(hits)\n",
        "\n",
        "    # дедуп по (source, chunk_id)\n",
        "    uniq = {}\n",
        "    for d in pool:\n",
        "        key = (d.metadata.get(\"source\"), d.metadata.get(\"chunk_id\"))\n",
        "        uniq[key] = d\n",
        "    pool = list(uniq.values())\n",
        "\n",
        "    pool = filter_by_metadata(pool, doc_type=doc_type)\n",
        "    return pool\n",
        "\n",
        "def build_context(ranked: List[Tuple[Document, float]], max_chars: int=3500) -> str:\n",
        "    out = []\n",
        "    total = 0\n",
        "    for d, sc in ranked:\n",
        "        snippet = d.page_content.strip()\n",
        "        header = f\"[source={d.metadata.get('source')} chunk={d.metadata.get('chunk_id')}/{d.metadata.get('chunk_total')} score={float(sc):.3f}]\\n\"\n",
        "        block = header + snippet + \"\\n\"\n",
        "        if total + len(block) > max_chars:\n",
        "            break\n",
        "        out.append(block)\n",
        "        total += len(block)\n",
        "    return \"\\n\".join(out)\n"
      ],
      "metadata": {
        "id": "trGHdDeOwiuO"
      },
      "execution_count": null,
      "outputs": []
    },
