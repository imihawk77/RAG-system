        "# Режем self-check программно до 3 пунктов\n",
        "def trim_self_check(text: str, max_items: int = 3) -> str:\n",
        "    lines = text.splitlines()\n",
        "    out = []\n",
        "    items = 0\n",
        "    in_item = False\n",
        "\n",
        "    for line in lines:\n",
        "        if line.startswith(\"- Утверждение:\"):\n",
        "            items += 1\n",
        "            if items > max_items:\n",
        "                break\n",
        "            in_item = True\n",
        "            out.append(line)\n",
        "            continue\n",
        "\n",
        "        # строки внутри текущего пункта (Статус/Источник)\n",
        "        if in_item:\n",
        "            out.append(line)\n",
        "\n",
        "    # если вдруг модель не соблюла формат — вернём безопасный минимум\n",
        "    if items == 0:\n",
        "        return \"Self-check:\\n- Утверждение: self-check не сформирован\\n  Статус: не подтверждено\\n  Источник: нет данных\"\n",
