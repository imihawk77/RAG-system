        "## Создание базы знаний"
      ],
      "metadata": {
        "id": "Gxjgl1X_LXfb"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import zipfile\n",
        "import os\n",
        "from pathlib import Path\n",
        "import json\n",
        "import shutil\n",
        "\n",
        "# Создаем временную директорию с базой знаний\n",
        "temp_kb_dir = Path(\"temp_kb_example\")\n",
        "if temp_kb_dir.exists():\n",
        "    shutil.rmtree(temp_kb_dir)\n",
        "temp_kb_dir.mkdir(parents=True)\n",
        "\n",
        "# Создаем структуру папок\n",
        "folders = [\"policies\", \"faq\", \"cases\", \"examples\", \"templates\"]\n",
        "for folder in folders:\n",
        "    (temp_kb_dir / folder).mkdir()\n",
        "\n",
        "# Создаем файлы с контентом\n",
        "\n",
        "## 1. Policies (Политики)\n",
        "policies = [\n",
        "    {\n",
        "        \"filename\": \"privacy_policy.txt\",\n",
        "        \"content\": \"\"\"Политика конфиденциальности\n",
        "\n",
        "1. Общие положения\n",
        "1.1. Настоящая Политика конфиденциальности определяет порядок обработки персональных данных.\n",
        "1.2. Оператор обязуется сохранять конфиденциальность персональных данных.\n",
        "1.3. Обработка персональных данных осуществляется в соответствии с законодательством.\n",
        "\n",
        "2. Состав персональных данных\n",
        "2.1. Фамилия, имя, отчество\n",
        "2.2. Контактные данные (телефон, email)\n",
        "2.3. Данные о профессиональной деятельности\n",
        "\n",
        "3. Цели обработки\n",
        "3.1. Заключение и исполнение договоров\n",
        "3.2. Информирование о новых услугах\n",
        "3.3. Улучшение качества обслуживания\n",
        "\n",
        "Дата последнего обновления: 2024-01-15\"\"\"\n",
        "    },\n",
        "    {\n",
        "        \"filename\": \"security_policy.txt\",\n",
        "        \"content\": \"\"\"Политика информационной безопасности\n",
        "\n",
        "1. Введение\n",
        "1.1. Цель политики - обеспечение защиты информации от угроз.\n",
        "1.2. Политика применяется ко всем информационным системам компании.\n",
        "\n",
        "2. Требования к паролям\n",
        "2.1. Минимальная длина пароля: 8 символов\n",
        "2.2. Обязательное использование заглавных букв и цифр\n",
        "2.3. Смена пароля каждые 90 дней\n",
        "\n",
        "3. Доступ к данным\n",
        "3.1. Принцип минимальных привилегий\n",
        "3.2. Двухфакторная аутентификация для администраторов\n",
        "3.3. Логирование всех операций с критичными данными\n",
        "\n",
        "4. Резервное копирование\n",
        "4.1. Ежедневное инкрементное копирование\n",
        "4.2. Еженедельное полное копирование\n",
        "4.3. Хранение резервных копий не менее 30 дней\n",
        "\n",
        "Ответственный за безопасность: Иван Петров\n",
        "Телефон: +7 (495) 123-45-67\"\"\"\n",
        "    },\n",
        "    {\n",
        "        \"filename\": \"work_from_home.md\",\n",
        "        \"content\": \"\"\"# Политика удаленной работы\n",
        "\n",
        "## 1. Цель\n",
        "Обеспечение эффективной работы сотрудников вне офиса.\n",
        "\n",
        "## 2. Условия\n",
        "- Стаж работы в компании от 6 месяцев\n",
        "- Наличие подходящего рабочего места дома\n",
        "- Стабильное интернет-соединение\n",
        "\n",
        "## 3. Технические требования\n",
        "### 3.1. Оборудование\n",
        "- Компьютер не старше 3 лет\n",
        "- Веб-камера и микрофон\n",
        "- Резервный источник питания\n",
        "\n",
        "### 3.2. ПО\n",
        "- Антивирусное ПО\n",
        "- VPN для доступа к корпоративным ресурсам\n",
        "- Мессенджер для связи\n",
        "\n",
        "## 4. Рабочий процесс\n",
        "- Ежедневный планер в 10:00\n",
        "- Отчет о выполнении задач в конце дня\n",
        "- Доступность с 9:00 до 18:00\n",
        "\n",
        "## 5. Компенсации\n",
        "- Интернет: 1000 руб./мес\n",
        "- Электричество: 500 руб./мес\n",
        "\n",
        "*Политика вступает в силу с 1 февраля 2025 года*\"\"\"\n",
        "    }\n",
        "]\n",
        "\n",
        "for policy in policies:\n",
        "    file_path = temp_kb_dir / \"policies\" / policy[\"filename\"]\n",
        "    file_path.write_text(policy[\"content\"], encoding='utf-8')\n",
        "\n",
        "## 2. FAQ (Часто задаваемые вопросы)\n",
        "faq_data = [\n",
        "    {\n",
        "        \"filename\": \"general_questions.txt\",\n",
